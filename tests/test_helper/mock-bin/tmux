#!/usr/bin/env bash
# Mock tmux — dispatches on subcommand, controllable via env vars
echo "tmux $*" >> "${MOCK_LOG_DIR:-/tmp}/tmux.log" 2>/dev/null || true

case "${1:-}" in
    -V)
        echo "tmux 3.4 (mock)"
        ;;
    list-sessions)
        if [[ "${MOCK_TMUX_SESSIONS:-}" == "none" ]]; then
            exit 1
        fi
        echo "${MOCK_TMUX_SESSIONS:-forge-test:1 windows}"
        ;;
    list-windows)
        echo "${MOCK_TMUX_WINDOWS:-0: forge-main (1 panes)}"
        ;;
    has-session)
        if [[ "${MOCK_TMUX_HAS_SESSION:-true}" == "true" ]]; then
            exit 0
        else
            exit 1
        fi
        ;;
    new-session)
        exit 0
        ;;
    new-window)
        exit 0
        ;;
    kill-session)
        exit 0
        ;;
    kill-window)
        exit 0
        ;;
    select-window)
        exit 0
        ;;
    attach-session)
        exit 0
        ;;
    *)
        exit 0
        ;;
esac
