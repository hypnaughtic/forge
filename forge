#!/usr/bin/env bash
# ==============================================================================
# Forge — Project Initialization Tool for Claude Code CLI Agent Teams
# ==============================================================================
# Thin wrapper that delegates to the Python CLI.
# Install: pip install -e . (or brew install forge-init)
# Usage: ./forge --config PATH [--project-dir DIR] [--validate-only]
set -euo pipefail

FORGE_DIR="${FORGE_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

# Check if the Python CLI is available
if command -v forge &>/dev/null; then
    exec forge "$@"
fi

# Fallback: try running from the local package
if command -v python3 &>/dev/null; then
    # Check if the package is installed in development mode
    if python3 -c "import forge_cli" 2>/dev/null; then
        exec python3 -m forge_cli.main "$@"
    fi

    # Try installing in development mode
    echo -e "${CYAN}[Forge]${NC} First run — installing forge CLI..."
    if pip install -e "$FORGE_DIR" 2>/dev/null || pip3 install -e "$FORGE_DIR" 2>/dev/null; then
        echo -e "${GREEN}[Forge]${NC} Installed successfully."
        exec python3 -m forge_cli.main "$@"
    fi
fi

echo -e "${RED}[Forge]${NC} Python 3.11+ is required. Install with: brew install python@3.12"
echo -e "${RED}[Forge]${NC} Then run: pip install -e $FORGE_DIR"
exit 1
