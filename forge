#!/usr/bin/env bash
# ==============================================================================
# Forge — AI Software Forge — Unified CLI Entry Point
# ==============================================================================
# Single entry point for all Forge operations.
# Usage: ./forge <command> [options]
set -euo pipefail

FORGE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="${FORGE_DIR}/scripts"
SHARED_DIR="${FORGE_DIR}/shared"
CONFIG_FILE="${FORGE_DIR}/config/team-config.yaml"
SNAPSHOTS_DIR="${SHARED_DIR}/.snapshots"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

log_info()  { echo -e "${GREEN}[Forge]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[Forge]${NC} $*"; }
log_error() { echo -e "${RED}[Forge]${NC} $*" >&2; }

print_banner() {
    echo -e "${CYAN}"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║     🔨 Forge — AI Software Forge   ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "${NC}"
}

usage() {
    print_banner
    echo "Usage: ./forge <command> [options]"
    echo ""
    echo "Commands:"
    echo "  setup                         One-time setup: validate deps, install prerequisites"
    echo "  init                          Interactive project setup (generates config + requirements)"
    echo "  start [--snapshot <path>]     Start a new session or resume from snapshot"
    echo "  stop [--pause]                Graceful shutdown with state snapshot"
    echo "  status                        Show all agent statuses, iteration progress, costs"
    echo "  cost                          Show cost breakdown by agent"
    echo "  tell \"<message>\"              Send natural language command to Team Leader"
    echo "  attach                        Attach to Team Leader's interactive tmux session"
    echo "  logs [--agent <name>] [--tail] View combined agent logs"
    echo ""
    echo "Examples:"
    echo "  ./forge setup                        # First-time setup"
    echo "  ./forge init                         # Interactive project config wizard"
    echo "  ./forge start                        # Start (auto-detects snapshots for resume)"
    echo "  ./forge stop                         # Graceful shutdown + snapshot"
    echo "  ./forge tell \"Switch to production-ready\"  # Command without entering tmux"
    echo "  ./forge attach                       # Enter Team Leader's tmux session"
    echo ""
    exit 0
}

# --- Command: setup ---
cmd_setup() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge setup"
        echo "  One-time setup: validates dependencies and prepares the environment."
        exit 0
    fi
    bash "${SCRIPTS_DIR}/setup.sh" "$@"
}

# --- Command: init ---
cmd_init() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge init"
        echo "  Interactive project setup wizard."
        echo "  Generates config/team-config.yaml and config/project-requirements.md."
        exit 0
    fi
    bash "${SCRIPTS_DIR}/init-project.sh" --wizard "$@"
}

# --- Command: start ---
cmd_start() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge start [--snapshot <path>]"
        echo "  Start a new session or resume from a previous snapshot."
        echo "  If a snapshot exists, you'll be prompted to resume."
        echo ""
        echo "Options:"
        echo "  --snapshot <path>   Resume from a specific snapshot file"
        exit 0
    fi

    print_banner

    # Check if a specific snapshot was requested
    local snapshot_path=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --snapshot)
                snapshot_path="$2"
                shift 2
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    # If specific snapshot provided, resume from it
    if [[ -n "$snapshot_path" ]]; then
        if [[ ! -f "$snapshot_path" ]]; then
            log_error "Snapshot file not found: $snapshot_path"
            exit 1
        fi
        log_info "Resuming from snapshot: $snapshot_path"
        bash "${SCRIPTS_DIR}/resume.sh" --snapshot "$snapshot_path"
        return
    fi

    # Check for existing snapshots
    if [[ -d "$SNAPSHOTS_DIR" ]]; then
        local latest_snapshot
        latest_snapshot=$(ls -t "${SNAPSHOTS_DIR}"/snapshot-*.json 2>/dev/null | head -1 || true)

        if [[ -n "$latest_snapshot" ]]; then
            # Extract snapshot info
            local snap_time=""
            local snap_iteration=""
            local snap_phase=""
            local snap_agents=""
            local snap_cost=""

            if command -v jq &>/dev/null; then
                snap_time=$(jq -r '.timestamp // "unknown"' "$latest_snapshot" 2>/dev/null || echo "unknown")
                snap_iteration=$(jq -r '.iteration.current // "?"' "$latest_snapshot" 2>/dev/null || echo "?")
                snap_phase=$(jq -r '.iteration.phase // "?"' "$latest_snapshot" 2>/dev/null || echo "?")
                snap_agents=$(jq -r '.agents | length // 0' "$latest_snapshot" 2>/dev/null || echo "0")
                snap_cost=$(jq -r '.costs.total_development_cost_usd // 0' "$latest_snapshot" 2>/dev/null || echo "0")
                local cost_cap
                cost_cap=$(jq -r '.costs.cost_cap_usd // "no-cap"' "$latest_snapshot" 2>/dev/null || echo "no-cap")
            fi

            log_info "Found previous session from ${snap_time}"
            log_info "  Iteration: ${snap_iteration} (phase: ${snap_phase})"
            log_info "  Agents: ${snap_agents} active | Cost: \$${snap_cost} / \$${cost_cap:-no-cap}"
            echo ""
            read -rp "[Forge] Resume? [Y/n/fresh] " choice
            choice="${choice:-Y}"

            case "$choice" in
                [Yy]|[Yy][Ee][Ss]|"")
                    log_info "Resuming..."
                    bash "${SCRIPTS_DIR}/resume.sh" --snapshot "$latest_snapshot"
                    return
                    ;;
                [Nn]|[Nn][Oo])
                    log_info "Exiting. Use './forge start --snapshot <path>' to resume a specific snapshot."
                    exit 0
                    ;;
                [Ff][Rr][Ee][Ss][Hh])
                    # Archive old snapshot
                    local archive_dir="${SNAPSHOTS_DIR}/archive"
                    mkdir -p "$archive_dir"
                    mv "$latest_snapshot" "$archive_dir/" 2>/dev/null || true
                    log_info "Old snapshot archived. Starting fresh session..."
                    bash "${SCRIPTS_DIR}/start.sh"
                    return
                    ;;
                *)
                    log_error "Invalid choice. Use Y (resume), n (exit), or fresh (new session)."
                    exit 1
                    ;;
            esac
        fi
    fi

    # No snapshot found — start fresh
    log_info "Starting fresh session..."
    bash "${SCRIPTS_DIR}/start.sh"
}

# --- Command: stop ---
cmd_stop() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge stop [--pause]"
        echo "  Graceful shutdown with state snapshot."
        echo ""
        echo "Options:"
        echo "  --pause   Stop agents but keep tmux session alive for inspection"
        exit 0
    fi
    bash "${SCRIPTS_DIR}/stop.sh" "$@"
}

# --- Command: status ---
cmd_status() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge status"
        echo "  Show all agent statuses, iteration progress, and costs."
        exit 0
    fi
    bash "${SCRIPTS_DIR}/status.sh" "$@"
}

# --- Command: cost ---
cmd_cost() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge cost"
        echo "  Show cost breakdown by agent."
        exit 0
    fi
    bash "${SCRIPTS_DIR}/cost-tracker.sh" --report "$@"
}

# --- Command: tell ---
cmd_tell() {
    if [[ "${1:-}" == "--help" || $# -eq 0 ]]; then
        echo "Usage: ./forge tell \"<message>\""
        echo "  Send a natural language command to the Team Leader."
        echo "  The message is written to shared/.human/override.md."
        echo ""
        echo "Examples:"
        echo "  ./forge tell \"Switch to production-ready mode\""
        echo "  ./forge tell \"Pause all work\""
        echo "  ./forge tell \"What's the status of the payment service?\""
        exit 0
    fi

    local message="$*"
    local override_file="${SHARED_DIR}/.human/override.md"

    # Ensure the directory exists
    mkdir -p "${SHARED_DIR}/.human"

    # Write the override file
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    cat > "$override_file" <<EOF
---
timestamp: ${timestamp}
type: directive
---

## Directive

${message}
EOF

    log_info "Message sent to Team Leader:"
    log_info "  \"${message}\""
    log_info "The Team Leader will process this at the next check cycle."
}

# --- Command: attach ---
cmd_attach() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge attach"
        echo "  Attach to the Team Leader's interactive tmux session."
        echo "  Press Ctrl+B then D to detach without stopping."
        exit 0
    fi

    # Find the forge tmux session
    local session_name
    session_name=$(tmux list-sessions 2>/dev/null | grep "^forge-" | head -1 | cut -d: -f1 || true)

    if [[ -z "$session_name" ]]; then
        log_error "No active Forge session found. Run './forge start' first."
        exit 1
    fi

    # Attach to the team-leader window
    local tl_window
    tl_window=$(tmux list-windows -t "$session_name" 2>/dev/null | grep "team-leader" | head -1 | cut -d: -f1 || true)

    if [[ -n "$tl_window" ]]; then
        tmux select-window -t "${session_name}:${tl_window}" 2>/dev/null || true
    fi

    tmux attach-session -t "$session_name"
}

# --- Command: logs ---
cmd_logs() {
    if [[ "${1:-}" == "--help" ]]; then
        echo "Usage: ./forge logs [--agent <name>] [--tail]"
        echo "  View combined agent logs."
        echo ""
        echo "Options:"
        echo "  --agent <name>   View logs for a specific agent"
        echo "  --tail           Follow logs in real-time"
        exit 0
    fi

    local agent=""
    local follow=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)
                agent="$2"
                shift 2
                ;;
            --tail)
                follow=true
                shift
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    local logs_dir="${SHARED_DIR}/.logs"

    if [[ ! -d "$logs_dir" ]]; then
        log_error "No logs directory found. Is a session running?"
        exit 1
    fi

    if [[ -n "$agent" ]]; then
        local log_file="${logs_dir}/${agent}.log"
        if [[ ! -f "$log_file" ]]; then
            log_error "No log file found for agent: $agent"
            exit 1
        fi
        if $follow; then
            tail -f "$log_file"
        else
            cat "$log_file"
        fi
    else
        local combined_log="${logs_dir}/combined.log"
        if [[ -f "$combined_log" ]]; then
            if $follow; then
                tail -f "$combined_log"
            else
                cat "$combined_log"
            fi
        else
            # Fallback: show all individual logs sorted by time
            if $follow; then
                tail -f "${logs_dir}"/*.log 2>/dev/null || log_error "No log files found."
            else
                cat "${logs_dir}"/*.log 2>/dev/null | sort || log_error "No log files found."
            fi
        fi
    fi
}

# --- Main Command Router ---
if [[ $# -eq 0 ]]; then
    usage
fi

COMMAND="$1"
shift

case "$COMMAND" in
    setup)    cmd_setup "$@" ;;
    init)     cmd_init "$@" ;;
    start)    cmd_start "$@" ;;
    stop)     cmd_stop "$@" ;;
    status)   cmd_status "$@" ;;
    cost)     cmd_cost "$@" ;;
    tell)     cmd_tell "$@" ;;
    attach)   cmd_attach "$@" ;;
    logs)     cmd_logs "$@" ;;
    --help|-h|help)
              usage ;;
    *)
        log_error "Unknown command: $COMMAND"
        echo "Run './forge --help' for usage information."
        exit 1
        ;;
esac
