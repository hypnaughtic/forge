# llm-gateway configuration (REQUIRED)
# All LLM calls are routed through the gateway — never directly to a provider
LLM_GATEWAY_URL=http://localhost:8080
LLM_GATEWAY_API_KEY=your-gateway-api-key-here

# Model settings (the gateway handles actual provider routing)
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# Agent settings
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true
