# llm-gateway configuration (REQUIRED)
# All LLM generation calls are routed through the gateway
LLM_GATEWAY_URL=http://localhost:8080
LLM_GATEWAY_API_KEY=your-gateway-api-key-here

# Generation model settings (the gateway routes to the actual provider)
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Embedding settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings
RETRIEVAL_TOP_K=5
